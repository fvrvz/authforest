		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Extract access_token from JSON response and set it as a collection variable\r",
									"let json = pm.response.json();\r",
									"if (json.access_token && json.refresh_token) {\r",
									"    pm.collectionVariables.set(\"accessToken\", json.access_token);\r",
									"    pm.collectionVariables.set(\"refreshToken\", json.refresh_token);\r",
									"    console.log(\"Tokens saved:\", {\r",
									"        accessToken: json.access_token,\r",
									"        refreshToken: json.refresh_token\r",
									"    });\r",
									"} else {\r",
									"    console.warn(\"No access_token found in response\");\r",
									"}\r",
									""
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"userId\": \"defaultuser\",\r\n    \"password\": \"defaultuserpass\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{hostname}}/api/{{apiVersion}}/auth/login",
							"host": [
								"{{hostname}}"
							],
							"path": [
								"api",
								"{{apiVersion}}",
								"auth",
								"login"
							]
						}
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Extract access_token from JSON response and set it as a collection variable\r",
									"let json = pm.response.json();\r",
									"if (json.access_token && json.refresh_token) {\r",
									"    pm.collectionVariables.set(\"accessToken\", json.access_token);\r",
									"    pm.collectionVariables.set(\"refreshToken\", json.refresh_token);\r",
									"    console.log(\"Tokens saved:\", {\r",
									"        accessToken: json.access_token,\r",
									"        refreshToken: json.refresh_token\r",
									"    });\r",
									"} else {\r",
									"    console.warn(\"No access_token found in response\");\r",
									"}\r",
									""
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"refresh_token\": \"{{refreshToken}}\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{hostname}}/api/{{apiVersion}}/auth/refresh",
							"host": [
								"{{hostname}}"
							],
							"path": [
								"api",
								"{{apiVersion}}",
								"auth",
								"refresh"
							]
						}
					},
					"response": []
				},
