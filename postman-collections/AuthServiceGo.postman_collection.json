        {
          "name": "Token Exchange (Auth Code)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set(\"oidcAccessToken\", json.access_token);",
                  "}",
                  "if (json.refresh_token) {",
                  "    pm.collectionVariables.set(\"oidcRefreshToken\", json.refresh_token);",
                  "}",
                  "if (json.id_token) {",
                  "    pm.collectionVariables.set(\"oidcIdToken\", json.id_token);",
                  "}",
                  ""
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
